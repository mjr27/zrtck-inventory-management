@using Microsoft.EntityFrameworkCore
@using ZRTCK.InventoryManagement.Persistence
@inject IDbContextFactory<InventoryDbContext> DbFactory

<MudTable Items="@PersonAssignments" Hover="true" Breakpoint="Breakpoint.Sm" Dense="true" Class="mt-4">
    <HeaderContent>
        <MudTh>Особа (Посада та ПІБ)</MudTh>
        <MudTh>Закріплене майно</MudTh>
        <MudTh Style="width: 50px;"></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Особа">
            <div class="d-flex flex-column">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@GetPersonPosition(context.PersonId)</MudText>
                <MudText Typo="Typo.body1">@GetPersonName(context.PersonId)</MudText>
            </div>
        </MudTd>
        <MudTd DataLabel="Закріплене майно">
            <div class="d-flex flex-column gap-2">
                @foreach (var itemId in context.InventoryItemIds)
                {
                    <div class="d-flex align-center justify-space-between mud-alert mud-alert-filled-info pa-1 px-2 rounded">
                        <MudText Typo="Typo.body2">@GetItemDisplay(itemId)</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" Color="Color.Inherit" 
                                       OnClick="@(() => RemoveItem(context, itemId))" Disabled="@Disabled" />
                    </div>
                }
                <div class="d-flex align-center mt-1">
                    <InventoryItemSelector Value="@_newItemId" 
                                          ValueChanged="@(id => AddItem(context, id))"
                                          Disabled="@Disabled"
                                          Label="Додати майно"
                                          Class="flex-grow-1"
                                          ExcludeIds="@GetAllSelectedItemIds()" />
                </div>
            </div>
        </MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" 
                           OnClick="@(() => RemovePersonRow(context))" Disabled="@Disabled" />
        </MudTd>
    </RowTemplate>
    <FooterContent>
        <MudTFootRow>
            <MudTd colspan="3">
                <div class="d-flex align-center gap-2 pa-2">
                    <PersonSelector Value="@_newPersonId" 
                                   ValueChanged="@OnNewPersonSelected" 
                                   Disabled="@Disabled" 
                                   Label="Додати особу до списку"
                                   Class="flex-grow-1" />
                </div>
            </MudTd>
        </MudTFootRow>
    </FooterContent>
</MudTable>

@code {
    public class PersonAssignmentModel
    {
        public int PersonId { get; set; }
        public List<string> InventoryItemIds { get; set; } = new();
    }

    [Parameter] public List<PersonAssignmentModel> PersonAssignments { get; set; } = new();
    [Parameter] public EventCallback<List<PersonAssignmentModel>> PersonAssignmentsChanged { get; set; }
    [Parameter] public bool Disabled { get; set; }

    private List<Person> _allPeople = new();
    private List<InventoryItem> _inventoryItems = new();
    private Dictionary<int, Person> _peopleMap = new();
    private Dictionary<string, InventoryItem> _itemsMap = new();

    private int? _newPersonId;
    private string? _newItemId;

    protected override async Task OnInitializedAsync()
    {
        await using var context = await DbFactory.CreateDbContextAsync();
        _allPeople = await context.People.ToListAsync();
        _inventoryItems = await context.Inventory.ToListAsync();
        
        _peopleMap = _allPeople.ToDictionary(p => p.Id);
        _itemsMap = _inventoryItems.ToDictionary(i => i.Id);
    }

    private string GetPersonName(int personId)
    {
        return _peopleMap.TryGetValue(personId, out var p) ? $"{p.LastName} {p.FirstName}" : "Невідомо";
    }

    private string GetPersonPosition(int personId)
    {
        return _peopleMap.TryGetValue(personId, out var p) ? p.Position : "";
    }

    private string GetItemDisplay(string itemId)
    {
        return _itemsMap.TryGetValue(itemId, out var i) ? $"{i.Name} ({i.Id})" : itemId;
    }

    private IEnumerable<string> GetAllSelectedItemIds()
    {
        return PersonAssignments.SelectMany(a => a.InventoryItemIds);
    }

    private async Task OnNewPersonSelected(int? personId)
    {
        if (personId.HasValue && personId.Value != -1)
        {
            if (PersonAssignments.All(a => a.PersonId != personId.Value))
            {
                PersonAssignments.Add(new PersonAssignmentModel { PersonId = personId.Value });
                await PersonAssignmentsChanged.InvokeAsync(PersonAssignments);
            }
            _newPersonId = null;
        }
    }

    private async Task AddItem(PersonAssignmentModel model, string? itemId)
    {
        if (!string.IsNullOrEmpty(itemId) && !model.InventoryItemIds.Contains(itemId))
        {
            model.InventoryItemIds.Add(itemId);
            await PersonAssignmentsChanged.InvokeAsync(PersonAssignments);
        }
        _newItemId = null;
    }

    private async Task RemoveItem(PersonAssignmentModel model, string itemId)
    {
        model.InventoryItemIds.Remove(itemId);
        await PersonAssignmentsChanged.InvokeAsync(PersonAssignments);
    }

    private async Task RemovePersonRow(PersonAssignmentModel model)
    {
        PersonAssignments.Remove(model);
        await PersonAssignmentsChanged.InvokeAsync(PersonAssignments);
    }
}
