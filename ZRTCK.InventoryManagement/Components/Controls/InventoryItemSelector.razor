@using Microsoft.EntityFrameworkCore
@using ZRTCK.InventoryManagement.Persistence
@inject IDbContextFactory<InventoryDbContext> DbFactory

<MudAutocomplete T="string"
                 @ref="_autocomplete"
                 Label="@Label"
                 Value="@Value"
                 ValueChanged="@OnValueChanged"
                 SearchFunc="@SearchItems"
                 ToStringFunc="@GetItemDisplay"
                 Text="@(_text)"
                 Clearable="true"
                 CoerceText="true"
                 ResetValueOnEmptyText="true"
                 Dense="true"
                 Variant="@Variant.Text"
                 Disabled="@Disabled"
                 Required="@Required"
                 RequiredError="@RequiredError"
                 Class="@Class"
                 ShowProgressIndicator="@(_allItems == null)"
                 UserAttributes="@(string.IsNullOrEmpty(Style) ? new Dictionary<string, object?>() : new Dictionary<string, object?> { { "style", Style } })">
    <ItemTemplate>
        <div class="d-flex align-center">
            @if (!string.IsNullOrEmpty(context) && _itemsMap.ContainsKey(context))
            {
                <MudIcon Icon="@Icons.Material.Filled.Inventory" Size="Size.Small" Class="mr-2"/>
                <MudText>
                    @GetItemDisplay(context)
                </MudText>
            }
        </div>
    </ItemTemplate>
</MudAutocomplete>

@code {
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public string Label { get; set; } = "Оберіть майно";
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool Required { get; set; }
    [Parameter] public string RequiredError { get; set; } = "Обов'язкове поле";
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Style { get; set; }

    [Parameter] public IEnumerable<string>? ExcludeIds { get; set; }

    private List<InventoryItem>? _allItems;
    private Dictionary<string, InventoryItem> _itemsMap = new();
    private string? _text;
    private MudAutocomplete<string> _autocomplete = null!;

    protected override async Task OnInitializedAsync()
    {
        await LoadItems();
    }

    private async Task LoadItems()
    {
        await using var context = await DbFactory.CreateDbContextAsync();
        _allItems = await context.Inventory
            .OrderBy(i => i.Name)
            .ToListAsync();

        _itemsMap = _allItems.ToDictionary(i => i.Id);
    }

    private Task<IEnumerable<string>> SearchItems(string? value, CancellationToken token)
    {
        if (_allItems == null)
        {
            return Task.FromResult(Enumerable.Empty<string>());
        }

        IEnumerable<InventoryItem> query = _allItems;

        if (ExcludeIds != null && ExcludeIds.Any())
        {
            query = query.Where(i => !ExcludeIds.Contains(i.Id));
        }

        if (!string.IsNullOrEmpty(value))
        {
            query = query.Where(i =>
                i.Name.Contains(value, StringComparison.OrdinalIgnoreCase) ||
                i.Id.Contains(value, StringComparison.OrdinalIgnoreCase));
        }

        return Task.FromResult(query.Select(i => i.Id));
    }

    private string GetItemDisplay(string? id)
    {
        if (string.IsNullOrEmpty(id)) return string.Empty;

        if (!_itemsMap.TryGetValue(id, out var item))
            return string.Empty;

        return $"{item.Name} ({item.Id})";
    }

    private async Task OnValueChanged(string? newValue)
    {
        Value = newValue ?? "";
        await ValueChanged.InvokeAsync(Value);
        await _autocomplete.ClearAsync();
    }

}
